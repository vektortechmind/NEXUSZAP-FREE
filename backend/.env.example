# Copie para .env e ajuste, ou rode install.sh na VPS para gerar automaticamente.
# O instalador gera automaticamente JWT_SECRET e ENCRYPTION_KEY.

NODE_ENV=development

# PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/nexus_chatbot_db?schema=public"

PORT=3000

# Desenvolvimento aceita minimo legado, mas producao exige 32+ caracteres e valor nao-default.
JWT_SECRET="change-me-min-16-chars!!"

# Obrigatorio em producao. Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# ENCRYPTION_KEY=""

ADMIN_EMAIL="admin@localhost.local"
# Desenvolvimento local apenas. Em producao use 12+ chars com maiuscula, minuscula, numero e simbolo.
ADMIN_PASSWORD="admin123"
ADMIN_SETUP_REQUIRED="true"

# Producao / VPS: origens do painel no browser (virgula). Dev: pode omitir.
APP_URL="http://localhost"
# CORS_ORIGINS="https://app.seudominio.com"
# CORS_ORIGINS="http://127.0.0.1:4173"

# Token de uso unico para /docker-setup e /criar-admin na instalacao inicial.
# SETUP_TOKEN=""
SETUP_COMPLETED="false"

# TELEGRAM_BOT_TOKEN=""

# OpenRouter (opcional; cabeçalhos HTTP)
# OPENROUTER_REFERER="https://seusite.com"
# OPENROUTER_TITLE="Meu Chatbot"

# Groq - audio (opcional; senao usa chave do painel)
# GROQ_AUDIO_KEY=""

# Auto-update/status consultivo
# Em producao, GITHUB_REPO e obrigatorio para /api/update/status.
GITHUB_REPO="vektortechmind/NEXUSZAP-FREE"

# A versao da aplicacao fica em backend/VERSION para poder ser atualizada pelo Git
# sem sobrescrever este .env local.
