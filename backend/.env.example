# Copie para .env e ajuste (ou use setup-env.ps1 / scripts/setup-env.sh).
# Valores abaixo satisfazem validação mínima local — troque JWT/ADMIN em produção.

NODE_ENV=development

# SQLite (caminho relativo à pasta prisma/)
DATABASE_URL="file:./chatbot.db"

PORT=3000

JWT_SECRET="change-me-min-16-chars!!"

# Opcional (base64 de 32 bytes). Se omitir, o backend cria backend/.encryption_key (gitignored).
# ENCRYPTION_KEY=""

ADMIN_EMAIL="admin@localhost.local"
ADMIN_PASSWORD="admin123"

# Produção / VPS: origens do painel no browser (vírgula). Dev: pode omitir.
# CORS_ORIGINS="https://app.seudominio.com"
# CORS_ORIGINS="http://127.0.0.1:4173"

# TELEGRAM_BOT_TOKEN=""

# OpenRouter (opcional; cabeçalhos HTTP)
# OPENROUTER_REFERER="https://seusite.com"
# OPENROUTER_TITLE="Meu Chatbot"

# Groq — áudio (opcional; senão usa chave do painel)
# GROQ_AUDIO_KEY=""

# Auto-update (opcional)
# GITHUB_REPO="owner/repo"
# APP_VERSION="v1.0.0"
# UPDATE_DIR="./updates"
# BACKUP_DIR="./backups"
