generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageChannel {
  WHATSAPP
  TELEGRAM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ChatMessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  REACTION
  BUTTONS_REPLY
  LIST_REPLY
  UNKNOWN
}

enum ChatMessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum IntegrationCredentialStatus {
  ACTIVE
  DISABLED
  REVOKED
}

enum IntegrationIngressStatus {
  ACCEPTED
  REJECTED_AUTH
  REJECTED_CONTRACT
  REJECTED_REPLAY
  REJECTED_DUPLICATE
  ERROR
}

enum IntegrationDispatchStatus {
  PENDING_RUNTIME
  SENT
  FAILED_INSTANCE_NOT_FOUND
  FAILED_INSTANCE_OFFLINE
  FAILED_RECIPIENT_MISSING
  FAILED_TEMPLATE_RENDER
  FAILED_SEND
  ERROR
}

enum ScheduledDispatchTargetType {
  NUMBER
  GROUP
}

enum ScheduledDispatchContentType {
  TEXT
  IMAGE
  VIDEO
}

enum ScheduledDispatchStatus {
  DRAFT
  SCHEDULED
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model Instance {
  id                  String         @id @default(uuid())
  slot                Int            @unique
  name                String         @default("Agente Principal")
  agentName           String?
  status              String         @default("DISCONNECTED")
  aiWhatsappEnabled   Boolean        @default(true)
  aiTelegramEnabled   Boolean        @default(true)
  typing              Boolean        @default(true)
  delayMin            Int            @default(4000)
  delayMax            Int            @default(7000)
  systemPrompt        String?
  telegramSystemPrompt String?
  telegramBotToken    String?
  chatProvider        String?
  groqKey             String?
  groqAudioKey        String?
  geminiKey           String?
  openaiKey           String?
  openaiModel         String?
  openrouterKey       String?
  openrouterModel     String?
  memoryLimit         Int            @default(5)
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now()) @updatedAt

  files               File[]
  messageEvents       MessageEvent[]
  conversations       Conversation[]
  messages            Message[]
  agent               Agent?
  integrationCredentials IntegrationCredential[]
  scheduledDispatchCampaigns ScheduledDispatchCampaign[]
  scheduledDispatches ScheduledDispatch[]

  @@index([slot])
}

model Agent {
  id              String   @id @default(uuid())
  name            String
  instanceId      String   @unique
  instance        Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  telegramEnabled Boolean  @default(true)
  systemPrompt    String?
  telegramSystemPrompt String?
  chatProvider    String?
  openaiModel     String?
  openrouterModel String?
  memoryLimit     Int      @default(5)
  audioTranscriptionEnabled Boolean @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  files           File[]

  @@index([name])
}

model File {
  id         String   @id @default(uuid())
  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  agentId    String?
  agent      Agent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  filename   String
  mimetype   String
  storagePath String?
  sizeBytes  Int      @default(0)
  data       Bytes?
  extracted  String?
  channel    String   @default("WHATSAPP")
  createdAt  DateTime @default(now())

  @@index([instanceId])
  @@index([agentId])
  @@index([channel])
  @@index([storagePath])
}

model Conversation {
  id             String    @id @default(uuid())
  instanceId     String
  instance       Instance  @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  jid            String
  remoteJidAlt   String?
  name           String?
  profilePicUrl  String?
  isGroup        Boolean   @default(false)
  lastMessageAt  DateTime
  unreadCount    Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  messages       Message[]

  @@unique([instanceId, jid])
  @@index([instanceId, lastMessageAt])
}

model Message {
  id                String            @id @default(uuid())
  conversationId    String
  conversation      Conversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  instanceId        String
  instance          Instance          @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  jid               String
  fromMe            Boolean
  body              String?
  messageType       ChatMessageType   @default(TEXT)
  status            ChatMessageStatus @default(SENT)
  providerMessageId String?
  senderJid         String?
  senderName        String?
  mediaUrl          String?
  mediaMimeType     String?
  mediaDurationMs   Int?
  reactionEmoji     String?
  editedAt          DateTime?
  isDeleted         Boolean           @default(false)
  quotedMessageId   String?
  createdAt         DateTime          @default(now())

  @@index([conversationId, createdAt])
  @@index([instanceId, providerMessageId])
  @@index([instanceId, jid, createdAt])
}

model MessageEvent {
  id         String           @id @default(uuid())
  instanceId String
  instance   Instance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  channel    MessageChannel
  direction  MessageDirection
  usedAi     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([instanceId])
  @@index([channel, createdAt])
  @@index([direction, createdAt])
  @@index([usedAi, createdAt])
}

model Session {
  id         String   @id @default(uuid())
  instanceId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([instanceId, key])
  @@index([instanceId])
}

model IntegrationCredential {
  id             String                      @id @default(uuid())
  instanceId     String
  instance       Instance                    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  tokenHash      String                      @unique
  encryptedToken String
  tokenPreview   String
  status         IntegrationCredentialStatus @default(ACTIVE)
  replayWindowMs Int                         @default(300000)
  dedupWindowMs  Int                         @default(300000)
  issuedAt       DateTime                    @default(now())
  lastUsedAt     DateTime?
  rotatedAt      DateTime?
  revokedAt      DateTime?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @default(now()) @updatedAt

  replayKeys     IntegrationReplayKey[]

  @@index([instanceId])
  @@index([instanceId, status])
  @@index([status])
}

model IntegrationReplayKey {
  id               String                @id @default(uuid())
  credentialId     String
  credential       IntegrationCredential @relation(fields: [credentialId], references: [id], onDelete: Cascade)
  dedupKey         String
  requestTimestamp DateTime
  expiresAt        DateTime
  createdAt        DateTime              @default(now())

  @@unique([credentialId, dedupKey])
  @@index([credentialId, expiresAt])
  @@index([expiresAt])
}

model IntegrationIngressLog {
  id               String                  @id @default(uuid())
  credentialId     String?
  instanceId       String?
  eventSlug        String?
  dedupKey         String?
  requestTimestamp DateTime?
  status           IntegrationIngressStatus
  failureCode      String?
  payloadJson      String?
  receivedAt       DateTime                @default(now())
  processedAt      DateTime?

  @@index([instanceId, receivedAt])
  @@index([status, receivedAt])
  @@index([dedupKey])
}

model IntegrationDispatchLog {
  id               String                    @id @default(uuid())
  ingressLogId     String?
  credentialId     String?
  instanceId       String?
  eventSlug        String?
  dedupKey         String?
  recipientJid     String?
  messageType      String?
  dispatchStatus   IntegrationDispatchStatus
  failureCode      String?
  providerMessageId String?
  payloadSummaryJson String?
  retryable        Boolean                   @default(false)
  retryAttemptCount Int                      @default(0)
  nextRetryAt      DateTime?
  lastRetryError   String?
  retryLockedAt    DateTime?
  retryExhaustedAt DateTime?
  createdAt        DateTime                  @default(now())
  processedAt      DateTime?

  @@index([instanceId, createdAt])
  @@index([dispatchStatus, createdAt])
  @@index([retryable, nextRetryAt])
  @@index([retryLockedAt])
  @@index([eventSlug, createdAt])
  @@index([dedupKey])
  @@index([ingressLogId])
}

model Settings {
  id          String   @id @default("github_update_settings")
  githubToken String?
  updatedAt   DateTime @updatedAt
}

model ScheduledDispatchCampaign {
  id                   String                      @id @default(uuid())
  instanceId           String
  instance             Instance                    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  targetType           ScheduledDispatchTargetType
  totalDestinations    Int
  baseScheduledAt      DateTime
  delaySeconds         Int                         @default(0)
  pauseEveryCount      Int                         @default(0)
  pauseDurationSeconds Int                         @default(0)
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @default(now()) @updatedAt

  dispatches           ScheduledDispatch[]

  @@index([instanceId, createdAt])
  @@index([instanceId, baseScheduledAt])
}

model ScheduledDispatch {
  id                String                      @id @default(uuid())
  instanceId        String
  instance          Instance                    @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  campaignId        String?
  campaign          ScheduledDispatchCampaign?  @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  targetType        ScheduledDispatchTargetType
  recipientPhone    String?
  recipientJid      String?
  contentType       ScheduledDispatchContentType
  body              String?
  mediaUrl          String?
  buttonsJson       String?
  scheduledAt       DateTime
  status            ScheduledDispatchStatus     @default(SCHEDULED)
  providerMessageId String?
  failureCode       String?
  providerError     String?
  processedAt       DateTime?
  createdAt         DateTime                    @default(now())
  updatedAt         DateTime                    @default(now()) @updatedAt

  @@index([instanceId, createdAt])
  @@index([instanceId, scheduledAt])
  @@index([campaignId])
  @@index([status, scheduledAt])
}
