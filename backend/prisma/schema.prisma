generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MessageChannel {
  WHATSAPP
  TELEGRAM
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Instance {
  id                  String         @id @default(uuid())
  name                String         @default("Agente Principal")
  agentName           String?
  status              String         @default("DISCONNECTED")
  aiWhatsappEnabled   Boolean        @default(true)
  aiTelegramEnabled   Boolean        @default(true)
  typing              Boolean        @default(true)
  delayMin            Int            @default(4000)
  delayMax            Int            @default(7000)
  systemPrompt        String?
  telegramSystemPrompt String?
  telegramBotToken    String?
  chatProvider        String?
  groqKey             String?
  groqAudioKey        String?
  geminiKey           String?
  openrouterKey       String?
  openrouterModel     String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @default(now()) @updatedAt

  files               File[]
  messageEvents       MessageEvent[]
}

model File {
  id         String   @id @default(uuid())
  instanceId String
  instance   Instance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  filename   String
  mimetype   String
  data       Bytes
  extracted  String?
  channel    String   @default("WHATSAPP")
  createdAt  DateTime @default(now())

  @@index([instanceId])
  @@index([channel])
}

model MessageEvent {
  id         String           @id @default(uuid())
  instanceId String
  instance   Instance         @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  channel    MessageChannel
  direction  MessageDirection
  usedAi     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([instanceId])
  @@index([channel, createdAt])
  @@index([direction, createdAt])
  @@index([usedAi, createdAt])
}

model Session {
  id         String   @id @default(uuid())
  instanceId String
  key        String
  value      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([instanceId, key])
  @@index([instanceId])
}

model Settings {
  id          String   @id @default("github_update_settings")
  githubToken String?
  updatedAt   DateTime @updatedAt
}
