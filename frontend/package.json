{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "1.0.6",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/ensure-env.mjs && tsc -b && vite build",
    "lint": "eslint .",
    "test:integration-audit-overview": "node ../node_modules/tsx/dist/cli.mjs --tsconfig tsconfig.app.json --test scripts/integration-audit-overview.test.ts",
    "test:integration-dashboard": "node --experimental-strip-types --test scripts/integration-dashboard-state.test.ts",
    "test:integration-credentials": "node ../node_modules/tsx/dist/cli.mjs --tsconfig tsconfig.app.json --test scripts/integration-credentials-state.test.tsx",
    "test:integration-workspace": "node ../node_modules/tsx/dist/cli.mjs --tsconfig tsconfig.app.json --test scripts/integration-workspace-state.test.tsx",
    "typecheck": "tsc -b",
    "preview": "vite preview",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "autoprefixer": "^10.5.0",
    "axios": "^1.16.1",
    "class-variance-authority": "^0.7.1",
    "lucide-react": "^1.16.0",
    "postcss": "^8.5.15",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
