# Login do painel = ADMIN_EMAIL e ADMIN_PASSWORD definidos em backend/.env (não use outro e-mail/senha).
#
# Opcional. Se não definir, o painel usa a API em http://localhost:3000/api (desenvolvimento local).
#
# Na VPS, defina no build (ou crie .env.production):
#   VITE_API_URL=https://seu-dominio.com/api
#
# VITE_API_URL=

# Opcional apenas para `npm run dev`: destino do proxy local do Vite para `/api` e `/ws/chat`.
# Use 3000 quando o backend local estiver nessa porta; use 3001 quando estiver usando o backend Docker publicado.
# VITE_DEV_API_TARGET=http://127.0.0.1:3000
